# 基础设施镜像版本
MYSQL_VERSION=8.0.36
REDIS_VERSION=7.2.13-alpine
ELASTICSEARCH_VERSION=8.12.0
NACOS_VERSION=v2.4.3-slim

# 端口映射
MYSQL_PORT=3306
REDIS_PORT=6379
ELASTICSEARCH_PORT=9200
NACOS_PORT=8848
NACOS_GRPC_PORT=9848

# MySQL
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=intelligent_customer_chat
MYSQL_USER=icc
MYSQL_PASSWORD=icc123456

# Elasticsearch
ES_JAVA_OPTS=-Xms1g -Xmx1g

# Nacos
NACOS_AUTH_ENABLE=false
NACOS_JVM_XMS=256m
NACOS_JVM_XMX=256m
NACOS_JVM_XMN=128m

# 应用本地运行建议环境变量
APP_MAIL_ENABLED=false
APP_MAIL_HOST=
APP_MAIL_PORT=993
APP_MAIL_USERNAME=
APP_MAIL_PASSWORD=
APP_MAIL_FOLDER=INBOX
APP_MAIL_MARK_SEEN_AFTER_FETCH=false
APP_MAIL_POLLING_ENABLED=false
APP_CONTEXT_MEMORY_ENABLED=false
APP_ELASTICSEARCH_URIS=http://127.0.0.1:9200
APP_ELASTICSEARCH_INDEX_NAME=knowledge_chunks
