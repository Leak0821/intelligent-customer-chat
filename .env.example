# 基础设施镜像版本
MYSQL_VERSION=8.0.36
REDIS_VERSION=7.2.13-alpine
ELASTICSEARCH_VERSION=8.12.0
NACOS_VERSION=v2.4.3-slim

# 端口映射
MYSQL_PORT=3306
REDIS_PORT=6379
ELASTICSEARCH_PORT=9200
NACOS_PORT=8848
NACOS_GRPC_PORT=9848

# MySQL
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=intelligent_customer_chat
MYSQL_USER=icc
MYSQL_PASSWORD=icc123456

# Elasticsearch
ES_JAVA_OPTS=-Xms1g -Xmx1g

# Nacos
NACOS_AUTH_ENABLE=false
NACOS_JVM_XMS=256m
NACOS_JVM_XMX=256m
NACOS_JVM_XMN=128m

# 应用本地运行建议环境变量
APP_MAIL_ENABLED=false
APP_MAIL_HOST=
APP_MAIL_PORT=993
APP_MAIL_USERNAME=
APP_MAIL_PASSWORD=
APP_MAIL_FOLDER=INBOX
APP_MAIL_MARK_SEEN_AFTER_FETCH=false
APP_MAIL_POLLING_ENABLED=false
APP_MAIL_OUTBOUND_ENABLED=false
APP_MAIL_OUTBOUND_PROVIDER=noop
APP_MAIL_OUTBOUND_FROM_ADDRESS=support@example.com
APP_MAIL_OUTBOUND_FROM_NAME=intelligent-customer-chat
APP_MAIL_OUTBOUND_HOST=
APP_MAIL_OUTBOUND_PORT=587
APP_MAIL_OUTBOUND_USERNAME=
APP_MAIL_OUTBOUND_PASSWORD=
APP_MAIL_OUTBOUND_AUTH_ENABLED=true
APP_MAIL_OUTBOUND_STARTTLS_ENABLED=true
APP_MAIL_OUTBOUND_SSL_ENABLED=false
APP_MAIL_OUTBOUND_CONNECTION_TIMEOUT_MILLIS=5000
APP_MAIL_OUTBOUND_TIMEOUT_MILLIS=5000
APP_MAIL_OUTBOUND_WRITE_TIMEOUT_MILLIS=5000
APP_MAIL_DISPATCH_RETRY_ENABLED=true
APP_MAIL_DISPATCH_RETRY_MAX_ATTEMPTS=3
APP_MAIL_DISPATCH_RETRY_INITIAL_DELAY_SECONDS=60
APP_MAIL_DISPATCH_RETRY_BACKOFF_MULTIPLIER=2
APP_MAIL_DISPATCH_RETRY_MAX_DELAY_SECONDS=900
APP_MAIL_DISPATCH_RETRY_BATCH_SIZE=20
APP_MAIL_DISPATCH_RETRY_LOCAL_SCHEDULER_ENABLED=true
APP_MAIL_DISPATCH_RETRY_LOCAL_FIXED_DELAY_MILLIS=60000
OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_CHAT_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_CHAT_MODEL=gpt-4o-mini
SPRING_AI_OPENAI_EMBEDDING_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
APP_AI_CHAT_ENABLED=false
APP_AI_CHAT_MAX_INPUT_LENGTH=6000
APP_AI_CHAT_TEMPERATURE=0.2
APP_CONTEXT_MEMORY_ENABLED=false
APP_CONTEXT_MEMORY_COMPRESSION_ENABLED=true
APP_CONTEXT_MEMORY_LLM_SUMMARY_ENABLED=false
APP_KNOWLEDGE_EMBEDDING_ENABLED=false
APP_KNOWLEDGE_EMBEDDING_MAX_INPUT_LENGTH=4000
APP_ELASTICSEARCH_ENABLED=false
APP_ELASTICSEARCH_URIS=http://127.0.0.1:9200
APP_ELASTICSEARCH_INDEX_NAME=knowledge_chunks
APP_ELASTICSEARCH_TITLE_FIELD=title
APP_ELASTICSEARCH_CONTENT_FIELD=content
APP_ELASTICSEARCH_VECTOR_FIELD=content_vector
APP_ELASTICSEARCH_PARENT_ID_FIELD=parent_id
APP_ELASTICSEARCH_DOC_TYPE_FIELD=doc_type
APP_ELASTICSEARCH_NUM_CANDIDATES=50
APP_ELASTICSEARCH_EMBEDDING_DIMENSIONS=16
APP_ELASTICSEARCH_RRF_K=60
APP_NACOS_CONFIG_ENABLED=false
APP_NACOS_SERVER_ADDR=127.0.0.1:8848
APP_NACOS_GROUP=DEFAULT_GROUP
APP_NACOS_PROMPT_DATA_ID=agent-prompts.json
APP_NACOS_INTENT_DATA_ID=agent-intents.json
APP_NACOS_RETRIEVAL_DATA_ID=agent-retrieval.json
APP_XXL_ENABLED=false
APP_XXL_ADMIN_ADDRESSES=http://127.0.0.1:8088/xxl-job-admin
APP_XXL_EXECUTOR_APP_NAME=intelligent-customer-chat-executor
APP_XXL_EXECUTOR_PORT=9999
